---
import Base from '../layouts/Base.astro';
import CatalogoMarca from '../components/CatalogoMarca.astro';
import { getProductos, aCard } from '../lib/productos.js';

const productos = (await getProductos())
  .filter((p) => p.seccion === 'tamashii')
  .map(aCard)
  .filter((p) => p.disp !== 'agotado');
const franquicias = [...new Set(productos.map((p) => p.fr).filter(Boolean))]
  .sort((a, b) => a.localeCompare(b, 'es'));
const total = productos.length;
---

<Base
  title="Tamashii Nations · figuras premium S.H. Figuarts bajo pedido | MOLOKA"
  description="Figuras Tamashii Nations y S.H. Figuarts, la gama premium de Bandai. Te las traemos bajo pedido en 10-15 días. Originales, desde España."
>
  <main class="wrap funko-page">
    <div class="sec-head">
      <h2>Tamashii Nations <span class="spark">&#10022;</span>
        <span class="sub">Figuras premium — <span id="cuenta">{total}</span> <span id="cuenta-lbl">{total === 1 ? 'pieza' : 'piezas'}</span></span>
      </h2>
    </div>

    {total > 0
      ? <CatalogoMarca productos={productos} franquicias={franquicias} />
      : <p class="vacio">Estamos cargando el catálogo. Vuelve pronto.</p>}
  </main>
</Base>
