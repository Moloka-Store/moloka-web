---
import Base from '../../layouts/Base.astro';
import Catalogo from '../../components/Catalogo.astro';
import { getProductos, aCard } from '../../lib/productos.js';
import { CATS } from '../../lib/categorias.js';

// Hub de la sección Funko: TODO el catálogo escrito en el HTML (SEO) + barra
// de categorías que lleva a cada página de categoría. Lee Supabase en el build.
const productos = (await getProductos()).map(aCard).filter((p) => p.disp !== 'agotado');
const presentes = CATS.filter((c) => productos.some((p) => p.cat === c));
const total = productos.length;
---

<Base
  title="Funko Pop · rarezas, CHASE y ediciones agotadas | MOLOKA"
  description="Catálogo de Funko Pop de Moloka Store: rarezas, ediciones CHASE, Vaulted y exclusivas. Navega por categoría y filtra por rareza y disponibilidad. Originales con envío desde España."
>
  <main class="wrap funko-page">
    <div class="sec-head">
      <h2>Funko Pop <span class="spark">&#10022;</span>
        <span class="sub">Todo el catálogo — <span id="cuenta">{total}</span> <span id="cuenta-lbl">{total === 1 ? 'pieza' : 'piezas'}</span></span>
      </h2>
    </div>

    {total > 0
      ? <Catalogo productos={productos} categorias={presentes} activa={null} />
      : <p class="vacio">Estamos preparando las primeras piezas. Vuelve pronto.</p>}
  </main>
</Base>
