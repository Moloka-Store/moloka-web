---
// Tarjeta de producto. Se renderiza EN EL BUILD: el nombre, el fandom, el
// precio y las etiquetas quedan escritos en el HTML que recibe Google.
// (Antes esto lo pintaba JavaScript en el navegador → SEO flojo.)
interface Producto {
  nm: string;
  fr: string;
  rars?: string[];
  disp: 'inmediato' | 'pedido' | 'reserva' | 'agotado';
  precio?: number | null;
  c1?: string;
  cat?: string | null;
  slug?: string;
  imagen?: string | null;
}
const { p } = Astro.props as { p: Producto };

const DISP = { inmediato:['Disponible','d-now'], pedido:['Bajo pedido','d-order'], reserva:['Reserva','d-pre'], agotado:['Agotado','d-out'] };
const RAR  = { chase:['CHASE','r-chase'], vaulted:['VAULTED','r-vaulted'], excl:['EXCLUSIVO','r-excl'] };
const BTN  = { inmediato:['Añadir',''], pedido:['Encargar','order'], reserva:['Reservar','pre'], agotado:['Avísame','out'] };

const [dl, dc] = DISP[p.disp] ?? DISP.inmediato;
const rars = p.rars ?? [];
const [bl, bc] = BTN[p.disp] ?? BTN.inmediato;
const color = p.c1 ?? '#a78bfa';
const precioFmt = p.precio != null ? p.precio.toLocaleString('es-ES', { minimumFractionDigits: 2 }) + ' €' : null;
const href = p.slug ? `/funko/${p.slug}` : '#';
---

<article class="card" data-fr={p.fr} data-nm={p.nm.toLowerCase()} data-cat={p.cat ?? ''} data-rars={rars.join(' ')} data-disp={p.disp} data-precio={p.precio ?? ''}>
  <a class="thumb" href={href} style={`background:linear-gradient(160deg,${color}12,${color}03)`}>
    <span class={`ribbon ${dc}`}><b>{dl}</b></span>
    <button class="fav" title="Guardar" type="button"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.7l-1-1.1a5.5 5.5 0 1 0-7.8 7.8l1.1 1L12 21l7.7-7.6 1.1-1a5.5 5.5 0 0 0 0-7.8Z"/></svg></button>
    {p.imagen
      ? <img class="foto" src={p.imagen} alt={p.nm} loading="lazy" />
      : <svg class="funko" viewBox="0 0 100 120" fill="none">
          <ellipse cx="50" cy="112" rx="26" ry="6" fill="rgba(0,0,0,.07)"/>
          <rect x="30" y="64" width="40" height="44" rx="9" fill={color}/>
          <rect x="30" y="64" width="40" height="44" rx="9" fill="#000" opacity=".06"/>
          <circle cx="50" cy="40" r="30" fill={color}/>
          <circle cx="40" cy="40" r="5.5" fill="#1a1a2e"/>
          <circle cx="60" cy="40" r="5.5" fill="#1a1a2e"/>
          <circle cx="41.6" cy="38" r="1.6" fill="#fff"/>
          <circle cx="61.6" cy="38" r="1.6" fill="#fff"/>
        </svg>}
  </a>
  <div class="meta">
    <div class="top">
      <span class="fr">{p.fr}</span>
      {rars.map((r) => { const [l, c] = RAR[r] ?? ['', '']; return l && <span class={`rar ${c}`}>{l}</span>; })}
    </div>
    <a class="nm" href={href}>{p.nm}</a>
    {precioFmt
      ? <div class="pr">{precioFmt}</div>
      : <div class="pr ask">Consultar precio</div>}
    <button class={`buy ${bc}`} type="button">{bl}</button>
  </div>
</article>
